generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  color     String   @default("#8b5cf6")
  icon      String   @default("📚")
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  cards     Card[]
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  author        String?
  language      String?
  filePath      String
  fileType      String // pdf | docx
  fileHash      String   @unique
  status        String   @default("uploaded") // uploaded | processing | done | failed
  pageCount     Int?
  cardCount     Int      @default(0)
  totalSegments Int      @default(0)
  doneSegments  Int      @default(0)
  error         String?
  createdAt     DateTime @default(now())
  cards         Card[]
}

model Card {
  id         Int          @id @default(autoincrement())
  categoryId Int
  category   Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bookId     Int?
  book       Book?        @relation(fields: [bookId], references: [id], onDelete: SetNull)
  type       String       @default("lesson") // lesson | fact | quiz | book
  title      String
  text       String
  quiz       Json? // {q, opts[], ok, expl}
  source     String       @default("seed") // seed | book | ai | web
  sourceRef  String?
  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  saved      SavedCard[]
  seen       SeenCard[]
  answers    QuizAnswer[]
  review     ReviewState[]

  @@index([categoryId, isActive])
  @@index([bookId])
}

// Nalozi — svaki user jedinstven, sa svojim napretkom. Lozinka je HEŠIRANA (bcrypt).
model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  username     String   @unique
  passwordHash String
  firstName    String?
  lastName     String?
  role         String   @default("user") // guest|user|premium|moderator|admin|superadmin
  paid         Boolean  @default(false) // pun pristup posle plaćanja
  flags        Json?    // otključani easter-egg-ovi / skriveni bedževi, npr. {"konami":true}
  createdAt    DateTime @default(now())

  state    UserState?
  saved    SavedCard[]
  seen     SeenCard[]
  answers  QuizAnswer[]
  signals  CardSignal[]
  reviews  ReviewState[]
}

model UserState {
  userId      Int       @id
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  streakCount Int       @default(0)
  lastVisit   DateTime?
  filters     Json?
}

model SavedCard {
  userId    Int
  cardId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, cardId])
}

model SeenCard {
  userId Int
  cardId Int
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  seenAt DateTime @default(now())

  @@id([userId, cardId])
}

model QuizAnswer {
  id         Int      @id @default(autoincrement())
  userId     Int
  cardId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card       Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  correct    Boolean
  answeredAt DateTime @default(now())

  @@index([userId])
}

// Spaced repetition (Anki-stil SM-2): raspored ponavljanja po korisniku i kartici.
model ReviewState {
  userId       Int
  cardId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  ease         Float    @default(2.5)
  intervalDays Float    @default(0)
  reps         Int      @default(0)
  lapses       Int      @default(0)
  dueAt        DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@id([userId, cardId])
  @@index([dueAt])
}

// Adaptivni signali: swipe desno = "know", levo = "dont_know", prolaz = "skip".
model CardSignal {
  id         Int      @id @default(autoincrement())
  userId     Int
  cardId     Int?
  categoryId Int
  kind       String // know | dont_know | skip
  dwellMs    Int      @default(0)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, categoryId])
  @@index([createdAt])
}
