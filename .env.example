# Kopiraj u .env i podesi po želji. .env se NIKAD ne komituje.

# ------- IZBOR AI PROVAJDERA -------
# ollama    = lokalni, besplatni model (podrazumevano za dev) — ne treba ključ
# openai    = OpenAI-kompatibilan API (Groq besplatno!) — za hosting bez jakog hardvera
# anthropic = Anthropic API (traži ANTHROPIC_API_KEY)
AI_PROVIDER=ollama

# --- Ollama (kad je AI_PROVIDER=ollama) ---
# Iz Docker kontejnera se host dostiže preko host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b
# Preuzmi model jednom na hostu:  ollama pull llama3.1:8b
# Ollama na CPU-u je spora (~5 tok/s). Timeout po pozivu (ms) — povećaj za velike odlomke:
OLLAMA_TIMEOUT_MS=900000
# NAPOMENA: za obradu VELIKIH knjiga (desetine segmenata) Ollama na CPU je nepraktična
# (sati po knjizi). Tada koristi AI_PROVIDER=openai sa Groq-om — isti model, ~100x brže.

# --- OpenAI-kompatibilan API (kad je AI_PROVIDER=openai) ---
# Groq: besplatan ključ na https://console.groq.com (llama-3.1-8b-instant je free)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=
OPENAI_MODEL=llama-3.1-8b-instant

# --- Anthropic (kad je AI_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...
GEN_MODEL=claude-sonnet-4-6
BULK_MODEL=claude-haiku-4-5

# Ako je "true", API pri startu automatski obrađuje nove knjige iz Baza znanja/
# (podrazumevano false da se ne troše resursi bez namere — koristi dugme "Skeniraj bazu znanja")
AUTO_PROCESS_ON_STARTUP=false

# Cron izraz za dnevno web-prikupljanje (prazno = isključeno), npr. "0 7 * * *"
DAILY_COLLECT_CRON=
